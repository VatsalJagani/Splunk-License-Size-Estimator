<form version="1.1" script="js/license_calculator.js" stylesheet="css/license_calculator.css">
  <label>Splunk License Size Estimator</label>
  <description>Calculate your estimated daily data volume based on your environment configuration</description>
  
  <fieldset submitButton="false">
    <html>
      <div class="calculator-container">
        <div class="input-section">
          <h2>Data Sources Configuration</h2>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="windows_enabled" class="source-checkbox"/>
              <label for="windows_enabled">Windows Servers</label>
            </div>
            <div class="number-input-container" id="windows_input_container" style="display:none;">
              <label for="windows_count">Number of Windows Servers (approx):</label>
              <input type="number" id="windows_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="sysmon_enabled" class="source-checkbox"/>
              <label for="sysmon_enabled">Sysmon for Windows Servers</label>
            </div>
            <div class="number-input-container" id="sysmon_input_container" style="display:none;">
              <label for="sysmon_count">Number of Windows Servers with Sysmon (approx):</label>
              <input type="number" id="sysmon_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="linux_enabled" class="source-checkbox"/>
              <label for="linux_enabled">Linux Servers</label>
            </div>
            <div class="number-input-container" id="linux_input_container" style="display:none;">
              <label for="linux_count">Number of Linux Servers (approx):</label>
              <input type="number" id="linux_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="ad_enabled" class="source-checkbox"/>
              <label for="ad_enabled">Active Directory</label>
            </div>
            <div class="number-input-container" id="ad_input_container" style="display:none;">
              <label for="ad_count">Number of Active Users (approx):</label>
              <input type="number" id="ad_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="firewalls_enabled" class="source-checkbox"/>
              <label for="firewalls_enabled">Firewalls</label>
            </div>
            <div class="number-input-container" id="firewalls_input_container" style="display:none;">
              <label for="firewalls_count">Number of Active Firewalls (approx):</label>
              <input type="number" id="firewalls_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="waf_enabled" class="source-checkbox"/>
              <label for="waf_enabled">WAF (Web Application Firewall)</label>
            </div>
            <div class="number-input-container" id="waf_input_container" style="display:none;">
              <label for="waf_count">Number of Active WAF (approx):</label>
              <input type="number" id="waf_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="data-source-group">
            <div class="checkbox-container">
              <input type="checkbox" id="switches_enabled" class="source-checkbox"/>
              <label for="switches_enabled">Switches</label>
            </div>
            <div class="number-input-container" id="switches_input_container" style="display:none;">
              <label for="switches_count">Number of Switches (approx):</label>
              <input type="number" id="switches_count" min="0" value="0" class="count-input"/>
            </div>
          </div>
          
          <div class="slider-container">
            <h3>Environment Size</h3>
            <div class="slider-wrapper">
              <label for="env_size">Size Factor (1-10):</label>
              <input type="range" id="env_size" min="1" max="10" value="5" step="1" class="env-slider"/>
              <span id="env_size_value" class="slider-value">5</span>
            </div>
            <p class="slider-description">Adjust this slider to reflect the relative size and activity level of your environment (5 = typical/average)</p>
          </div>
        </div>
        
        <div class="output-section">
          <h2>Estimated License Size</h2>
          <div class="result-box">
            <div class="result-value">
              <span id="total_size">0</span> GB/day
            </div>
            <div class="result-breakdown" id="breakdown">
              <!-- Breakdown will be populated by JavaScript -->
            </div>
          </div>
          
          <div class="notes-section">
            <h3>Important Notes</h3>
            <div class="note-box">
              <h4>Additional Application Logs</h4>
              <p>Some application logs can vary from minimum size to Terabytes depending on the environment size. These should be measured separately:</p>
              <ul>
                <li><strong>Cloudflare:</strong> minimum 20 GB</li>
                <li><strong>Custom Applications:</strong> minimum 5-10 GB</li>
              </ul>
            </div>
            
            <div class="note-box">
              <h4>Cloud Tenancy Logs</h4>
              <p>Cloud tenancy log sizes are typically small and not included in the calculation above. However, if your estimated license is below 20 GB, you should separately account for:</p>
              <ul>
                <li>EntraID/Office365</li>
                <li>Google Workspace</li>
                <li>AWS CloudTrail</li>
                <li>Tenable</li>
                <li>Qualys</li>
                <li>And other cloud services</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </html>
  </fieldset>
</form>
